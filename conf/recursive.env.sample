# --- Core services ---
OS_HOST="https://127.0.0.1:9200"
OSD_HOST="http://127.0.0.1:5601"
OSD_HOST_LAN="http://CHANGE_THIS"
OS_USER="CHANGE_THIS"
OS_PASS="CHANGE_THIS"
OS_CACERT="/etc/recursive-ir/logstash/certs/opensearch-ca.pem"

# --- Runtime paths ---
WATCH_ROOT="/var/log/recursive-ir/cases"
LOG_ROOT="/var/log/recursive-ir"
UMASK=0022
PARSERS_YML="/etc/recursive-ir/conf/parsers.yml"


# Identity (resolved by dfir init when seeding this file)
RI_USER=@RI_USER@
RI_GROUP=@RI_GROUP@

# Numeric identity (also resolved by dfir init)
RI_UID=@RI_UID@
RI_GID=@RI_GID@

MAIL_PROVIDER=m365
MAIL_SMTP_USER=your-sender-mailbox@yourdomain.com

MS_TENANT_ID=common
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional but supported (confidential clients); leave blank for public client style.
# MS_CLIENT_SECRET=xxxxx

# Defaults we use if omitted:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
