# --- Core services ---
OS_HOST="https://127.0.0.1:9200"
OSD_HOST="http://127.0.0.1:5601"
OSD_HOST_LAN="http://CHANGE_THIS"
OS_USER="admin"
OS_PASS="CHANGE_THIS"
OS_CACERT="/etc/recursive-ir/certs/opensearch/root-ca.pem"

# --- Runtime paths ---
WATCH_ROOT="/var/log/recursive-ir/cases"
LOG_ROOT="/var/log/recursive-ir"
UMASK=0022
PARSERS_YML="/etc/recursive-ir/conf/parsers.yml"


# Identity (resolved by dfir init when seeding this file)
RI_USER=@RI_USER@
RI_GROUP=@RI_GROUP@

# Numeric identity (also resolved by dfir init)
RI_UID=@RI_UID@
RI_GID=@RI_GID@

