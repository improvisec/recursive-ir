# --- Core services ---
OS_HOST="https://127.0.0.1:9200"
OSD_HOST="http://CHANGE_THIS:5601"
OS_USER="CHANGE_THIS"
OS_PASS="CHANGE_THIS"
OS_CACERT="/etc/recursive-ir/logstash/certs/opensearch-ca.pem"

# --- Runtime paths ---
WATCH_ROOT="/var/log/recursive-ir/cases"
LOG_ROOT="/var/log/recursive-ir"
UMASK=0022
PARSERS_YML="/etc/recursive-ir/conf/parsers.yml"

# --- Load repo paths written by dfir init ---
. /etc/recursive-ir/conf/paths.env

# --- Extend PATH dynamically ---
PATH="$RI_BIN:$RI_SCRIPTS:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"

